# Application
APP_NAME=AI Recruit Consult Platform
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-secure-random-string-at-least-32-chars
APP_API_PREFIX=/api/v1
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=recruit
POSTGRES_PASSWORD=recruit_secret
POSTGRES_DB=recruit_platform
DATABASE_URL=postgresql+asyncpg://recruit:recruit_secret@postgres:5432/recruit_platform

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=recruit-platform
MINIO_SECURE=false

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Logging
LOG_LEVEL=INFO
LOG_JSON=false
