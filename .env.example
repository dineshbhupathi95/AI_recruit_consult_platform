# Application
APP_NAME=AI Recruit Consult Platform
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-secure-random-string-at-least-32-chars
APP_API_PREFIX=/api/v1
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=recruit
POSTGRES_PASSWORD=recruit_secret
POSTGRES_DB=recruit_platform
# Docker Compose (backend container uses host "postgres")
DATABASE_URL=postgresql+asyncpg://recruit:recruit_secret@postgres:5432/recruit_platform
# Local development (run Postgres via Docker, migrate from host machine)
# DATABASE_URL=postgresql+asyncpg://recruit:recruit_secret@localhost:5432/recruit_platform

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=recruit-platform
MINIO_SECURE=false

# File storage (MinIO when available; falls back to project `files/` folder)
# STORAGE_BACKEND=auto
# LOCAL_FILES_DIR=files

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# AI Provider (openai | mock for tests/local without API key)
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

#GEMINI_API_KEY=AIzaSyCHk1-0JcNpaX_u0qF5qq8hkThqtxThAgs
#GEMINI_MODEL=gemini-2.5-flash
#GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

AI_REQUEST_TIMEOUT_SECONDS=120

# Google Gemini (optional env fallback)
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Groq — free tier at https://console.groq.com
# AI_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# Local open-source models via Ollama (free — no API key)
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2
# Docker Compose backend uses OLLAMA_BASE_URL=http://ollama:11434/v1 automatically


Groq_api=